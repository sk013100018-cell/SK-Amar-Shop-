<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>[Sk Amar Shop] | Digital Apparel Architecture</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;400;900&family=Playfair+Display:ital,wght@1,900&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <!-- FontAwesome for Social Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        :root { --bg: #050505; --accent: #ffffff; }
        body { background-color: var(--bg); color: white; font-family: 'Inter', sans-serif; overflow-x: hidden; }
        .mono { font-family: 'JetBrains Mono', monospace; }
        .serif { font-family: 'Playfair Display', serif; }
        .stagger-item { opacity: 0; transform: translateY(30px); }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.1); }
        
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }

        .masonry { column-count: 2; column-gap: 1.5rem; }
        @media (min-width: 768px) { .masonry { column-count: 3; } }
        .masonry-item { break-inside: avoid; margin-bottom: 1.5rem; }

        #checkoutModal { transition: opacity 0.5s ease; pointer-events: none; opacity: 0; z-index: 200; }
        #checkoutModal.active { pointer-events: all; opacity: 1; }
        
        .sold-out { filter: grayscale(1); opacity: 0.5; pointer-events: none; }
        
        /* Social & Footer Styling */
        .social-btn:hover { background: white; color: black; transform: scale(1.1); transition: 0.4s ease; }
        footer a:hover { color: #888; transition: 0.3s; }
    </style>
</head>
<body>

    <!-- Status Bar -->
    <div class="fixed top-0 w-full z-[100] bg-white text-black py-1 px-4 flex justify-between items-center text-[10px] font-bold tracking-widest uppercase mono">
        <span>System Status: Synchronized</span>
        <span class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2 animate-pulse"></span> Live Sync Active</span>
    </div>

    <!-- Navigation -->
    <nav class="fixed w-full z-50 px-6 py-10 flex justify-between items-center transition-all duration-500" id="nav">
        <div class="text-3xl font-black tracking-tighter serif italic">[Sk Amar Shop]</div>
        <div class="hidden md:flex space-x-10 text-[11px] font-light uppercase tracking-[0.3em]">
            <a href="#collection">Collection</a>
            <a href="#tech">Technology</a>
            <a href="#connect">Contact</a>
        </div>
        <button onclick="openCart()" class="text-[11px] font-bold border-b border-white pb-1 mono">CART (<span id="cart-count">0</span>)</button>
    </nav>

    <!-- Hero Section -->
    <section class="relative h-screen flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#050505] z-10"></div>
            <img src="https://images.unsplash.com/photo-1578681994506-b8f463449011?q=80&w=2000" class="w-full h-full object-cover scale-110" id="heroImage">
        </div>
        <div class="relative z-20 text-center">
            <h2 class="text-[10px] tracking-[0.8em] uppercase mb-4 stagger-item">Architectural Streetwear</h2>
            <h1 class="text-7xl md:text-9xl font-black tracking-tighter mb-8 stagger-item uppercase leading-none">THE DROP<br><span class="serif italic font-light text-6xl md:text-8xl lowercase">v.01 archive</span></h1>
            <a href="#collection" class="px-12 py-4 bg-white text-black font-bold uppercase text-xs tracking-widest hover:bg-gray-200 transition-all inline-block stagger-item">Shop now</a>
        </div>
    </section>

    <!-- Collection Section -->
    <section id="collection" class="py-32 px-6 max-w-[1400px] mx-auto">
        <div class="mb-20">
            <span class="text-xs text-zinc-500 mono mb-2 block tracking-widest uppercase underline">Available Grid</span>
            <h3 class="text-5xl font-bold tracking-tighter italic serif uppercase">The Assets.</h3>
        </div>
        <div class="masonry" id="productGrid">
            <!-- Loaded from LocalStorage -->
        </div>
    </section>

    <!-- Contact Panel & Social Media (New Section) -->
    <section id="connect" class="py-32 border-t border-zinc-900 bg-[#080808]">
        <div class="max-w-[1400px] mx-auto px-6 grid md:grid-cols-2 gap-20 items-center">
            <div class="stagger-item text-center md:text-left">
                <h4 class="text-[10px] tracking-[0.5em] uppercase text-zinc-500 mb-6">Contact Panel</h4>
                <h2 class="text-5xl md:text-7xl font-black italic serif mb-10 leading-none lowercase">Connect with <br>the architect.</h2>
            </div>
            
            <div class="flex flex-wrap justify-center md:justify-end gap-8 stagger-item">
                <!-- WhatsApp -->
                <a href="https://wa.me/8801905824710" target="_blank" class="social-btn flex items-center gap-4 border border-zinc-800 p-6 px-10 rounded-full transition-all">
                    <i class="fab fa-whatsapp text-2xl"></i>
                    <span class="text-xs font-black uppercase tracking-widest">WhatsApp</span>
                </a>
                <!-- Instagram -->
                <a href="#" target="_blank" class="social-btn flex items-center gap-4 border border-zinc-800 p-6 px-10 rounded-full transition-all">
                    <i class="fab fa-instagram text-2xl"></i>
                    <span class="text-xs font-black uppercase tracking-widest">Instagram</span>
                </a>
                <!-- Facebook -->
                <a href="https://www.facebook.com/share/1CTVbG9a9f/" target="_blank" class="social-btn flex items-center gap-4 border border-zinc-800 p-6 px-10 rounded-full transition-all">
                    <i class="fab fa-facebook-f text-2xl"></i>
                    <span class="text-xs font-black uppercase tracking-widest">Facebook</span>
                </a>
            </div>
        </div>
    </section>

    <!-- Checkout Modal -->
    <div id="checkoutModal" class="fixed inset-0 flex items-center justify-center p-6 bg-black/95 backdrop-blur-xl">
        <div class="glass max-w-lg w-full p-10 relative">
            <button onclick="closeCart()" class="absolute top-5 right-5 text-white mono text-[10px] uppercase">Close [X]</button>
            <h2 class="text-3xl font-black tracking-tighter serif mb-8 uppercase">Order Deployment</h2>
            <div id="cartItemsList" class="mb-6 space-y-3 text-sm mono text-zinc-400 border-b border-zinc-800 pb-6"></div>
            <div class="space-y-4">
                <input type="text" id="custName" placeholder="Full Name" class="w-full bg-zinc-900 border border-zinc-800 p-4 text-xs mono uppercase outline-none focus:border-white">
                <input type="text" id="custPhone" placeholder="Contact (WhatsApp)" class="w-full bg-zinc-900 border border-zinc-800 p-4 text-xs mono uppercase outline-none focus:border-white">
                <textarea id="custAddress" placeholder="Delivery Address" class="w-full bg-zinc-900 border border-zinc-800 p-4 text-xs mono uppercase outline-none focus:border-white h-24"></textarea>
                <button onclick="submitOrder()" class="w-full bg-white text-black py-5 text-[11px] font-black uppercase tracking-[0.3em] hover:bg-zinc-200 transition-all">Submit Deployment</button>
            </div>
        </div>
    </div>

    <!-- Footer Section (New) -->
    <footer class="py-24 border-t border-zinc-900 px-6 bg-[#050505]">
        <div class="max-w-[1400px] mx-auto grid md:grid-cols-3 gap-16 items-start">
            <div>
                <div class="text-4xl font-black tracking-tighter serif italic mb-6">[Sk Amar Shop]</div>
                <p class="text-[10px] text-zinc-500 uppercase tracking-[0.3em] leading-loose">
                    High-fidelity apparel <br> engineered for the <br> modern pioneer.
                </p>
            </div>
            <div class="flex flex-col gap-4 text-[11px] font-bold uppercase tracking-widest">
                <a href="#collection">Collection</a>
                <a href="#tech">Technology
                    <h1>
                        আমাদের টি-শার্টে ব্যবহৃত কাপড় উন্নত মানের এবং আরামদায়ক। আমরা দীর্ঘস্থায়ী ও আকর্ষণীয় ডিজাইন তৈরি করতে আধুনিক প্রিন্টিং প্রযুক্তি ব্যবহার করি।
                 </h1>
                </a>
                <a href="#connect">Contact Panel
                   
                </a>
               <div class="social-icons" style="display: flex; gap: 20px;">
    <a href="https://www.facebook.com/share/1CTVbG9a9f/" target="_blank">
        <img src="https://cdn-icons-png.flaticon.com/512/733/733547.png" alt="Facebook" style="width: 30px; height: 30px;">
    </a>

    <a href="#" target="_blank">
        <img src="https://cdn-icons-png.flaticon.com/512/733/733558.png" alt="Instagram" style="width: 30px; height: 30px;">
    </a>

    <a href="#" target="_blank">
        <img src="https://cdn-icons-png.flaticon.com/512/1384/1384060.png" alt="YouTube" style="width: 30px; height: 30px;">
    </a>

    <a href="#" target="_blank">
        <img src="https://cdn-icons-png.flaticon.com/512/3536/3536505.png" alt="LinkedIn" style="width: 30px; height: 30px;">
    </a>

    <a href="#" target="_blank">
        <img src="https://cdn-icons-png.flaticon.com/512/733/733585.png" alt="WhatsApp" style="width: 30px; height: 30px;">
    </a>
</div>

                 <h> 
                        আমাদের টি-শার্ট সম্পর্কে কোনো প্রশ্ন বা মতামত থাকলে, নিচের মাধ্যমে আমাদের সাথে যোগাযোগ করতে পারেন। আমরা দ্রুত উত্তর দেওয়ার চেষ্টা করব।
                    </h>
            </div>
            <div class="text-left md:text-right">
                <p class="text-[10px] text-zinc-700 uppercase tracking-widest mb-4">Location: Bangladesh</p>
                <p class="text-[10px] text-zinc-700 uppercase tracking-widest">© 2024 *Sk Amar Shop* Apparel Architecture</p>
                <p class="text-[9px] text-zinc-800 mt-2 uppercase">System Architect: SK</p>
            </div>
        </div>
    </footer>

    <script>
        const DB_KEY = "SK_LIVE_DATABASE";
        const ORDER_KEY = "SK_ORDERS_DATABASE";
        let cart = [];

        function loadProducts() {
            const grid = document.getElementById('productGrid');
            const products = JSON.parse(localStorage.getItem(DB_KEY)) || [];
            
            grid.innerHTML = products.map(p => `
                <div class="masonry-item group cursor-pointer stagger-item ${p.status === 'Sold Out' ? 'sold-out' : ''}">
                    <div class="relative overflow-hidden bg-zinc-900 aspect-[3/4]">
                        <img src="${p.imgUrl}" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105">
                        ${p.status === 'Sold Out' ? '<div class="absolute inset-0 flex items-center justify-center font-black text-xs uppercase tracking-widest bg-black/40">Out of Stock</div>' : ''}
                    </div>
                    <div class="py-6 flex justify-between items-start">
                        <div>
                            <h4 class="font-bold text-lg uppercase">${p.name}</h4>
                            <p class="text-[10px] text-zinc-500 mono uppercase">${p.status}</p>
                        </div>
                        <div class="text-right">
                            ${p.oldPrice ? `<p class="text-[10px] text-zinc-500 line-through mono mb-1 italic">৳${p.oldPrice}</p>` : ''}
                            <span class="text-lg font-light mono">৳${p.price}</span>
                        </div>
                    </div>
                    <button onclick="addToCart('${p.name}', ${p.price})" class="w-full py-3 border border-zinc-800 text-[10px] font-black uppercase tracking-widest hover:bg-white hover:text-black transition">Add to Grid</button>
                </div>
            `).join('');
            
            gsap.to(".stagger-item", { opacity: 1, y: 0, duration: 1, stagger: 0.1, scrollTrigger: { trigger: ".stagger-item", start: "top 90%" } });
        }

        function addToCart(name, price) {
            cart.push({ name, price });
            updateCartUI();
            openCart();
        }

        function updateCartUI() {
            document.getElementById('cart-count').innerText = cart.length;
            document.getElementById('cartItemsList').innerHTML = cart.map(i => `<div class="flex justify-between"><span>${i.name}</span><span>৳${i.price}</span></div>`).join('');
        }

        function openCart() { document.getElementById('checkoutModal').classList.add('active'); }
        function closeCart() { document.getElementById('checkoutModal').classList.remove('active'); }

        function submitOrder() {
            const name = document.getElementById('custName').value;
            const phone = document.getElementById('custPhone').value;
            const address = document.getElementById('custAddress').value;

            if(!name || !phone || !address || cart.length === 0) return alert("System Error: Missing Data");

            const order = {
                id: Math.floor(1000 + Math.random() * 9000),
                customer: name,
                phone: phone,
                address: address,
                items: cart,
                total: cart.reduce((s, i) => s + i.price, 0),
                date: new Date().toLocaleString()
            };

            let orders = JSON.parse(localStorage.getItem(ORDER_KEY)) || [];
            orders.push(order);
            localStorage.setItem(ORDER_KEY, JSON.stringify(orders));

            alert("Deployment Successfully Initialized!");
            cart = [];
            window.location.reload();
        }

        window.onload = loadProducts;
        gsap.registerPlugin(ScrollTrigger);
    </script>
</body>
</html>
